# ZoneGuard Pulse — Feature 14
# Environment variable example file
# Copy relevant vars into your .env (or .env.local for frontend)
# ALL vars are prefixed FEATURE14_ as required by project conventions.

# ---------------------------------------------------------------------------
# Backend (FastAPI) — add to backend/.env or root .env
# ---------------------------------------------------------------------------

# Percentage of trigger threshold at which push-notification alerts fire (default 75)
FEATURE14_ALERT_THRESHOLD_PCT=75.0

# Noise floor for anonymised rider count: count is rounded down to nearest multiple (default 3)
FEATURE14_ZONE_ACTIVITY_NOISE_FLOOR=3

# Number of 6-hour buckets in the 72-hour disruption chart (default 12 = 72 hours)
FEATURE14_72H_BUCKETS=12

# Maximum characters for the WhatsApp brief text (default 800)
FEATURE14_WHATSAPP_MAX_CHARS=800

# ---------------------------------------------------------------------------
# Frontend (Vite / React) — add to frontend/.env or frontend/.env.local
# VITE_ prefix required for Vite to expose vars to the browser bundle.
# FEATURE14 appears after VITE_ as the feature namespace.
# ---------------------------------------------------------------------------

# Auto-refresh interval for the Pulse dashboard in milliseconds (default 30000 = 30s)
VITE_FEATURE14_POLL_INTERVAL_MS=30000
